<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.library.backend.mapper.BookMapper">

    <resultMap id="BaseResultMap" type="com.library.backend.entity.Book">
            <id property="bookId" column="book_id" />
            <result property="title" column="title" />
            <result property="author" column="author" />
            <result property="publisher" column="publisher" />
            <result property="publishDate" column="publish_date" />
            <result property="price" column="price" />
            <result property="category" column="category" />
            <result property="location" column="location" />
            <result property="totalCount" column="total_count" />
            <result property="availableCount" column="available_count" />
            <result property="status" column="status" />
            <result property="description" column="description" />
            <result property="coverUrl" column="cover_url" />
    </resultMap>

    <sql id="Base_Column_List">
        book_id,title,author,publisher,publish_date,price,
        category,location,total_count,available_count,status,
        description,cover_url
    </sql>
</mapper>
